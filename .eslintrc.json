{
  "env": {
    "node": true,
    "mocha": true,
    "es2021": true
  },
  "globals": {
    "driver": "readonly",
    "browser": "readonly",
    "$": "readonly",
    "$$": "readonly"
  },
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "semi": ["error", "always"],
    "eqeqeq": ["error", "always"],
    "no-var": "error"
  }
}

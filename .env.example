# ─── BrowserStack Credentials ────────────────────────────────────────────────
# Obtenha em: https://app.browserstack.com/accounts/settings
BROWSERSTACK_USER=your_username
BROWSERSTACK_KEY=your_access_key
# ID do app gerado após upload no BrowserStack (ex: bs://abc123...)
BROWSERSTACK_ANDROID_APP=bs://your_app_id_here
# Nome da build exibido no painel BrowserStack (opcional)
BUILD_NAME=Mobile Regression

# ─── Execução ─────────────────────────────────────────────────────────────────
# RUN_ON_BS=true  → executa no BrowserStack
# RUN_ON_BS=false → executa no emulador local (padrão)
RUN_ON_BS=false

# ─── Appium local (ignorado quando RUN_ON_BS=true) ───────────────────────────
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# ─── Dispositivo local (ignorado quando RUN_ON_BS=true) ──────────────────────
DEVICE_NAME=Android Emulator
PLATFORM_NAME=Android
AUTOMATION_NAME=UiAutomator2

# ─── Tunning opcional ─────────────────────────────────────────────────────────
LOG_LEVEL=error
WAIT_TIMEOUT=20000
MOCHA_TIMEOUT=120000
